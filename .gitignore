# ── Secrets / local state ──────────────────────────────────────────────────────
# Runtime secrets — never commit
.env

# CUPS volume bind-mounts (populated at runtime by docker-compose)
cups-config/*
!cups-config/.gitkeep
cups-logs/*
!cups-logs/.gitkeep
cups-spool/*
!cups-spool/.gitkeep

# Canon driver tarball (large binary, downloaded by download-driver.sh)
# These are now tracked in git to prevent missing files during builds.
# Keep the download/ directory.
!download/.gitkeep
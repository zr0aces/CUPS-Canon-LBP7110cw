# ── Secrets / sensitive config ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env-example .env
#   nano .env
#
# Do NOT commit .env to version control (.gitignore excludes it).
# ──────────────────────────────────────────────────────────────────────────────

# Required: your Canon printer's IP address.
# Find it by pressing the WiFi button on the printer to print a network page,
# or check your router's DHCP leases table.
PRINTER_IP=192.168.1.100

# Required: CUPS Web UI admin password.
# Change this before going to production.
ADMIN_PASSWORD=changeme

# Optional overrides (uncomment to change):
# PRINTER_NAME=Canon_LBP7110Cw
# PRINTER_PPD=CNRCUPSLBP7110CZNK.ppd
# CUPS_LOGLEVEL=warn     # error | warn | info | debug
# CUPS_ENV_DEBUG=no      # yes = full bash -x trace (very verbose)